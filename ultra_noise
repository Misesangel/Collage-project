#include <stdio.h>
#include <string.h>

struct Student {
    int roll;
    char name[50];
    float marks;
};

void addStudent(struct Student s[], int *count) {
    printf("Enter Roll: ");
    scanf("%d", &s[*count].roll);
    printf("Enter Name: ");
    scanf("%s", s[*count].name);
    printf("Enter Marks: ");
    scanf("%f", &s[*count].marks);
    (*count)++;
}

void displayStudents(struct Student s[], int count) {
    for (int i = 0; i < count; i++) {
        printf("\nRoll: %d | Name: %s | Marks: %.2f", s[i].roll, s[i].name, s[i].marks);
    }
    printf("\n");
}

int main() {
    struct Student s[100];
    int count = 0, choice;

    while (1) {
        printf("\n1. Add Student\n2. Display All\n3. Exit\nChoice: ");
        scanf("%d", &choice);

        if (choice == 1) addStudent(s, &count);
        else if (choice == 2) displayStudents(s, count);
        else if (choice == 3) break;
        else printf("Invalid choice!\n");
    }
    return 0;
}
